# ========================
# Python / environment
# ========================
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv/

# ========================
# OS / IDE
# ========================
.DS_Store
.idea/
.vscode/

# ========================
# Logs
# ========================
data/logs/
data/scans_log.csv
*.log

# ========================
# V2 data lifecycle local/private/generated data
# ========================
data/local/*
!data/local/.gitkeep

data/raw/*
!data/raw/.gitkeep

data/generated/*
!data/generated/.gitkeep

# Normalized production-like inputs require explicit approval before tracking
data/normalized/*
!data/normalized/.gitkeep

# ========================
# Processed data (block all ticker files)
# ========================
data/processed/*.csv

# Historical evidence artifacts are generated locally.
data/history/

# ========================
# Allow these core files
# ========================
!data/processed/market_regime.csv
!data/processed/scanner_ranked.csv

# (optionally add later if needed)
# !data/processed/validation_summary.csv

# ========================
# Watchlist data (state = preserved)
# ========================
# Do not ignore: belongs to system state

# ========================
# Portfolio data (state = preserved)
# ========================
# Do not ignore: belongs to system state

# ========================
# Reports (generated)
# ========================
reports/daily/
reports/archive/
reports/*.md

# ========================
# Jupyter / temp (future proof)
# ========================
.ipynb_checkpoints/

# ========================
# Misc
# ========================
*.tmp
*.bak
